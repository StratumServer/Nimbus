<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(FrameworkVersion)</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <RootNamespace>Nimbus.Proxy</RootNamespace>
    <AssemblyName>Nimbus.Proxy</AssemblyName>
    <Configurations>Debug;Release;PerfTest</Configurations>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nimbus.Api\Nimbus.Api.csproj" />
    <ProjectReference Include="..\Nimbus.Shared\Nimbus.Shared.csproj" />
    <ProjectReference Include="..\Nimbus.Registry.Core\Nimbus.Registry.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Tomlyn" Version="0.19.0" />
  </ItemGroup>
</Project>
